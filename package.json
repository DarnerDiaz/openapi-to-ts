{
  "name": "openapi-to-ts",
  "version": "1.0.0",
  "description": "Transform OpenAPI 3.0 specifications into TypeScript interfaces automatically",
  "main": "dist/cli.js",
  "bin": {
    "openapi-to-ts": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "start": "node dist/cli.js",
    "publish-devto": "tsc && node dist/scripts/devto-publisher.js"
  },
  "keywords": [
    "openapi",
    "swagger",
    "typescript",
    "interfaces",
    "types",
    "code-generation"
  ],
  "author": "Darner Diaz",
  "license": "MIT",
  "devDependencies": {
    "@vitest/ui": "^4.1.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
